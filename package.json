{
  "name": "mixpanel",
  "description": "A simple server-side API for mixpanel",
  "keywords": [
    "mixpanel",
    "analytics",
    "api",
    "stats"
  ],
  "version": "0.21.0",
  "homepage": "https://github.com/mixpanel/mixpanel-node",
  "author": "Carl Sverre",
  "license": "MIT",
  "workspaces": [
    "packages/openfeature-server-provider"
  ],
  "main": "lib/mixpanel-node",
  "directories": {
    "lib": "lib"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mixpanel/mixpanel-node.git"
  },
  "engines": {
    "node": ">=10.0"
  },
  "scripts": {
    "test": "vitest",
    "test:all": "npm run test && npm run test --workspaces --if-present",
    "build:workspaces": "npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "lint": "oxlint ."
  },
  "types": "./lib/mixpanel-node.d.ts",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.8",
    "nock": "^14.0.10",
    "oxlint": "^1.16.0",
    "prettier": "^3.6.2",
    "proxyquire": "^2.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "https-proxy-agent": "7.0.6",
    "json-logic-js": "2.0.5"
  }
}
